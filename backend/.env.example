# Servidor
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
CORS_ORIGIN=*

# Banco de Dados
DB_HOST=localhost
DB_PORT=5432
DB_NAME=carolina_nail_design
DB_USER=postgres
DB_PASSWORD=password
DATABASE_URL=
DB_SSL=false

# JWT
JWT_SECRET=sua_chave_secreta_muito_segura_aqui
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d
PIN_RESET_TOKEN_EXPIRE=10m

# Email
SMTP_TRANSPORT=auto
# Opções: smtp, ethereal, stream
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_app
SMTP_FROM=noreply@carolinanaildesign.com
SMTP_SECURE=false
EXPOSE_RECOVERY_CODE=false
RECOVERY_CODE_EXPIRY_MINUTES=10
RECOVERY_MAX_VERIFY_ATTEMPTS=5
RECOVERY_MAX_REQUESTS_PER_HOUR=5
RECOVERY_MIN_REQUEST_INTERVAL_SECONDS=60
CONFIRMATION_JOB_CRON=0 20 * * *
CONFIRMATION_EXPIRY_CHECK_CRON=0 * * * *
CONFIRMATION_PENDING_EXPIRY_HOURS=12

# SMS (opcional - Twilio)
SMS_SENDER=CarolinaNails
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=

# Notificações
NOTIFICATION_API_KEY=sua_chave_api

# Cliente Frontend
REACT_APP_API_URL=http://localhost:3000/api
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# Google Drive Backup
GOOGLE_DRIVE_ENABLED=false
GOOGLE_DRIVE_CREDENTIALS_PATH=./credentials.json
GOOGLE_DRIVE_FOLDER_ID=sua-pasta-id

# AWS S3 Backup
AWS_ENABLED=false
AWS_ACCESS_KEY_ID=sua_chave_id
AWS_SECRET_ACCESS_KEY=sua_chave_secreta
AWS_REGION=us-east-1
AWS_BACKUP_BUCKET=carolina-nail-backups

# Dropbox Backup
DROPBOX_ENABLED=false
DROPBOX_ACCESS_TOKEN=seu_token_dropbox

# Local Backups
BACKUP_RETENTION_DAYS=30
BACKUP_MAX_LOCAL_COPIES=5
